# Database Configuration
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db
DATABASE_URL=postgresql://your_user:your_password@your_host/your_db

# Application Secrets
SECRET_KEY=your_secret_key

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_BASE_URL=http://localhost:11433/v1
OPENAI_MAX_RETRIES=3
LLM_CONCURRENCY_LIMIT=4096
LLM_TEMPERATURE=0.0
LLM_SYSTEM_PROMPT="You are a biomedical literature reviewer..."

# NCBI API Configuration
NCBI_API_KEY=your_ncbi_api_key
NCBI_MAX_REQUESTS_PER_SECOND=10.0
HTTP_TIMEOUT_SEC=180.0
MAX_RETRIES=30
RETRY_BACKOFF_BASE_SEC=1.5

# Thread Counts
SEARCH_THREAD_COUNT=4
FETCH_THREAD_COUNT=8

# Docker Configuration
DOCKER_NETWORK_NAME=hypothesis-network
